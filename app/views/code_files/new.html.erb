<%# app/views/code_files/new.html.erb %>

<div class="min-h-screen bg-[#0a0a0f] font-['DM_Sans',sans-serif]">
  <%= render "shared/navbar" %>

  <main class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <%= render "shared/flash" %>

    <nav class="flex items-center gap-2 text-sm text-zinc-600 mb-8">
      <%= link_to "Projects", projects_path, class: "hover:text-zinc-400 transition-colors" %>
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <%= link_to @project.name, project_path(@project), class: "hover:text-zinc-400 transition-colors" %>
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="text-zinc-400">Add Code File</span>
    </nav>

    <div class="rounded-2xl border border-white/[0.07] bg-white/[0.03] p-8 shadow-2xl">
      <h1 class="text-white text-2xl font-semibold mb-1">Add Code File</h1>
      <p class="text-zinc-500 text-sm mb-8">Paste your code or upload a file to get an AI review.</p>

      <% if @code_file.errors.any? %>
        <div class="mb-6 rounded-xl border border-red-500/25 bg-red-500/10 p-4">
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-4 h-4 text-red-400 shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
            <p class="text-red-400 text-sm font-medium">Please fix the following errors:</p>
          </div>
          <ul class="space-y-1 pl-6 list-disc">
            <% @code_file.errors.full_messages.each do |msg| %>
              <li class="text-red-300 text-sm"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: [@project, @code_file], data: { turbo: true }, class: "space-y-5" do |f| %>

        <%# Language %>
        <div class="space-y-1.5">
          <%= f.label :language, class: "block text-xs font-medium text-zinc-400 uppercase tracking-wider" %>
          <%= f.select :language,
                options_for_select([
                  ["Ruby", "ruby"],
                  ["Python", "python"],
                  ["JavaScript", "javascript"],
                  ["TypeScript", "typescript"],
                  ["C++", "cpp"],
                  ["Java", "java"],
                  ["Go", "go"],
                  ["Rust", "rust"],
                  ["Other", "other"]
                ], @code_file.language),
                { include_blank: "Select a language..." },
                class: "w-full rounded-xl border #{@code_file.errors[:language].any? ? 'border-red-500/50 bg-red-500/5' : 'border-white/10 bg-white/5'}
                        text-white py-3 px-4 text-sm
                        focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50
                        transition-all duration-200 hover:border-white/20" %>
          <% if @code_file.errors[:language].any? %>
            <p class="text-red-400 text-xs flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
              <%= @code_file.errors[:language].first %>
            </p>
          <% end %>
        </div>

        <%# Paste code %>
        <div class="space-y-1.5">
          <%= f.label :content, "Paste Code", class: "block text-xs font-medium text-zinc-400 uppercase tracking-wider" %>
          <%= f.text_area :content,
                placeholder: "Paste your code here...",
                rows: 14,
                class: "w-full rounded-xl border #{@code_file.errors[:content].any? ? 'border-red-500/50 bg-red-500/5' : 'border-white/10 bg-white/5'}
                        text-zinc-200 placeholder-zinc-600 font-mono
                        py-3 px-4 text-sm leading-6
                        focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50
                        transition-all duration-200 hover:border-white/20 resize-none bg-[#0d0d14]" %>
        </div>

        <%# OR divider %>
        <div class="flex items-center gap-3">
          <div class="flex-1 h-px bg-white/[0.06]"></div>
          <span class="text-zinc-600 text-xs">or upload a file</span>
          <div class="flex-1 h-px bg-white/[0.06]"></div>
        </div>

        <%# File upload %>
        <div class="space-y-1.5">
          <%= f.label :file, "Upload File", class: "block text-xs font-medium text-zinc-400 uppercase tracking-wider" %>
          <%= f.file_field :file,
                class: "w-full text-sm text-zinc-400
                        file:mr-4 file:py-2 file:px-4
                        file:rounded-lg file:border-0
                        file:text-sm file:font-medium
                        file:bg-violet-500/10 file:text-violet-300
                        hover:file:bg-violet-500/20 file:cursor-pointer
                        file:transition-all file:duration-200" %>
          <p class="text-zinc-600 text-xs">Max 200KB. Accepted: .rb, .py, .js, .cpp, .txt</p>
        </div>

        <%# Buttons %>
        <div class="flex items-center gap-3 pt-2">
          <%= f.submit "Add File",
                class: "px-6 py-2.5 rounded-xl text-sm font-semibold text-white
                        bg-gradient-to-r from-violet-600 to-indigo-600
                        hover:from-violet-500 hover:to-indigo-500
                        active:scale-[0.98] transition-all duration-200
                        shadow-lg shadow-violet-500/20 cursor-pointer" %>
          <%= link_to "Cancel", project_path(@project),
                class: "px-6 py-2.5 rounded-xl text-sm font-medium text-zinc-400
                        border border-white/10 hover:border-white/20 hover:text-white
                        transition-all duration-200" %>
        </div>

      <% end %>
    </div>
  </main>
</div>