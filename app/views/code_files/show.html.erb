<%# app/views/code_files/show.html.erb %>

<div class="min-h-screen bg-[#0a0a0f] font-['DM_Sans',sans-serif]">
  <%= render "shared/navbar" %>

  <main class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <%= render "shared/flash" %>

    <nav class="flex items-center gap-2 text-sm text-zinc-600 mb-6">
      <%= link_to "Projects", projects_path, class: "hover:text-zinc-400 transition-colors" %>
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <%= link_to @project.name, project_path(@project), class: "hover:text-zinc-400 transition-colors" %>
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="text-zinc-400"><%= @code_file.language %></span>
    </nav>

    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-lg bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center">
          <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
          </svg>
        </div>
        <div>
          <h1 class="text-white font-semibold text-xl"><%= @code_file.language %></h1>
          <div class="flex items-center gap-3 mt-0.5">
            <span class="text-xs text-zinc-500"><%= @code_file.language.presence || "Unknown language" %></span>
            <span class="text-zinc-700">·</span>
            <span class="text-xs text-zinc-500">Added <%= @code_file.created_at.strftime("%b %d, %Y") %></span>
          </div>
        </div>
      </div>

      <% last_review = @code_file.review %>
      <% if last_review&.status == "pending" %>
        <div class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold text-amber-300 bg-amber-500/10 border border-amber-500/20">
          <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
          </svg>
          AI Reviewing...
        </div>
      <% else %>
        <%= button_to code_file_review_path(@code_file),
              method: :post,
              data: { turbo_stream: true },
              class: "inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 shadow-lg shadow-violet-500/20 active:scale-[0.98] transition-all duration-200 cursor-pointer border-0" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
          Run AI Review
        <% end %>
      <% end %>
    </div>

    <%# Split Layout %>
    <div class="grid grid-cols-1 xl:grid-cols-5 gap-5 mb-8">

      <%# LEFT — Code Panel %>
      <div class="xl:col-span-3 flex flex-col rounded-2xl border border-white/[0.07] overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 bg-[#111118] border-b border-white/[0.06]">
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
            <span class="w-3 h-3 rounded-full bg-amber-500/70"></span>
            <span class="w-3 h-3 rounded-full bg-emerald-500/70"></span>
          </div>
          <span class="text-xs text-zinc-500 font-mono"><%= @code_file.language %></span>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-mono bg-indigo-500/10 text-indigo-300 border border-indigo-500/15">
            <%= @code_file.language.presence || "txt" %>
          </span>
        </div>

        <div class="relative flex-1 bg-[#0d0d14] overflow-auto max-h-[600px]">
          <div class="flex">
            <div class="select-none py-5 px-4 text-right min-w-[3rem] bg-[#0d0d14] border-r border-white/[0.04]">
              <% code_content = @code_file.content.presence || "" %>
              <% code_content.lines.each_with_index do |_, i| %>
                <div class="text-xs text-zinc-700 font-mono leading-6"><%= i + 1 %></div>
              <% end %>
            </div>
            <pre class="flex-1 py-5 px-5 text-sm font-mono text-zinc-200 leading-6 overflow-x-auto whitespace-pre"><%= code_content %></pre>
          </div>
        </div>
      </div>

      <%# RIGHT — AI Review Panel %>
      <div class="xl:col-span-2 flex flex-col gap-4" id="review-panel">
        <% if last_review %>
          <div class="rounded-2xl border border-white/[0.07] bg-white/[0.03] p-5">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-white font-semibold">AI Review</h2>
              <% if last_review.status == "completed" %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-300 border border-emerald-500/20">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
                  Completed
                </span>
              <% elsif last_review.status == "pending" %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-500/10 text-amber-300 border border-amber-500/20">
                  <svg class="w-3 h-3 animate-spin" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                  </svg>
                  Processing...
                </span>
              <% else %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-red-500/10 text-red-300 border border-red-500/20">
                  <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span>
                  Failed
                </span>
              <% end %>
            </div>
            <p class="text-zinc-600 text-xs">Reviewed <%= last_review.created_at.strftime("%B %d, %Y at %H:%M") %></p>
          </div>

          <% if last_review.status == "completed" && last_review.result.present? %>
            <div class="flex-1 rounded-2xl border border-white/[0.07] bg-white/[0.03] overflow-hidden">
              <div class="px-5 py-4 border-b border-white/[0.06] flex items-center gap-2">
                <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
                <h3 class="text-white font-medium text-sm">Issues Found</h3>
              </div>
              <div class="divide-y divide-white/[0.04] max-h-[480px] overflow-y-auto">
                <% begin %>
                  <% issues = JSON.parse(last_review.result) rescue nil %>
                  <% if issues.is_a?(Array) && issues.any? %>
                    <% issues.each_with_index do |issue, idx| %>
                      <div class="p-4 hover:bg-white/[0.02] transition-colors">
                        <div class="flex items-start gap-3">
                          <span class="shrink-0 w-7 h-7 rounded-lg bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-xs font-mono text-amber-300 font-semibold">
                            <%= issue["line"] || (idx + 1) %>
                          </span>
                          <div class="flex-1 min-w-0">
                            <p class="text-zinc-200 text-sm leading-snug mb-1.5"><%= issue["issue"] || issue["message"] || issue.to_s %></p>
                            <% if issue["suggestion"].present? %>
                              <p class="text-zinc-500 text-xs leading-relaxed">💡 <%= issue["suggestion"] %></p>
                            <% end %>
                          </div>
                        </div>
                      </div>
                    <% end %>
                  <% else %>
                    <div class="p-5">
                      <p class="text-zinc-300 text-sm leading-relaxed whitespace-pre-wrap"><%= last_review.result %></p>
                    </div>
                  <% end %>
                <% end %>
              </div>
            </div>

          <% elsif last_review.status == "pending" %>
            <div class="rounded-2xl border border-white/[0.07] bg-white/[0.03] p-8 flex flex-col items-center text-center">
              <div class="w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-amber-400 animate-spin" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                </svg>
              </div>
              <p class="text-zinc-300 text-sm font-medium mb-1">AI is reviewing your code</p>
              <p class="text-zinc-600 text-xs">This usually takes 5–15 seconds. Refresh to see results.</p>
            </div>
          <% end %>

        <% else %>
          <div class="rounded-2xl border border-dashed border-white/[0.1] bg-white/[0.02] flex flex-col items-center justify-center py-16 text-center px-6">
            <div class="w-14 h-14 rounded-2xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-violet-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
              </svg>
            </div>
            <h3 class="text-zinc-300 text-sm font-semibold mb-2">No review yet</h3>
            <p class="text-zinc-600 text-xs leading-relaxed mb-5">Click "Run AI Review" above to analyze this code.</p>
            <div class="flex flex-col items-center gap-1.5">
              <div class="flex items-center gap-2 text-xs text-zinc-600">
                <svg class="w-3.5 h-3.5 text-emerald-500/60" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                Detects bugs & logic errors
              </div>
              <div class="flex items-center gap-2 text-xs text-zinc-600">
                <svg class="w-3.5 h-3.5 text-emerald-500/60" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                Suggests improvements
              </div>
              <div class="flex items-center gap-2 text-xs text-zinc-600">
                <svg class="w-3.5 h-3.5 text-emerald-500/60" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                Powered by Hugging Face AI
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Comments Section %>
    <div class="rounded-2xl border border-white/[0.07] bg-white/[0.03] overflow-hidden">
      <div class="px-6 py-5 border-b border-white/[0.06] flex items-center gap-2">
        <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        <h2 class="text-white font-semibold">Comments</h2>
        <span class="ml-auto text-xs text-zinc-600 bg-white/5 border border-white/10 rounded-full px-2.5 py-1"><%= last_review&.comments&.count || 0 %></span>
      </div>

      <div class="p-6 border-b border-white/[0.06]" id="comment-form">
        <% if last_review %>
          <%= form_with(url: code_file_review_comments_path(@code_file), method: :post, data: { turbo_stream: true }, class: "flex gap-3 items-start") do |f| %>
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center text-white text-xs font-semibold shrink-0 mt-0.5">
              <%= current_user.name.first.upcase rescue "?" %>
            </div>
            <div class="flex-1 flex gap-2">
              <%= f.text_area :content, placeholder: "Add a comment…", rows: 1,
                    class: "flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-2.5 text-sm text-white placeholder-zinc-600 resize-none focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 hover:border-white/20 transition-all duration-200" %>
              <%= f.submit "Post", class: "shrink-0 px-4 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 active:scale-[0.98] transition-all duration-200 cursor-pointer shadow-lg shadow-violet-500/20" %>
            </div>
          <% end %>
        <% else %>
          <p class="text-zinc-600 text-sm text-center">Run an AI review first to enable comments.</p>
        <% end %>
      </div>

      <div id="comments" class="divide-y divide-white/[0.04]">
        <%= render last_review.comments.order(created_at: :asc) if last_review %>
      </div>

      <% if last_review.nil? || last_review.comments.empty? %>
        <div class="flex flex-col items-center justify-center py-12 text-center" id="no-comments">
          <p class="text-zinc-600 text-sm">No comments yet. Be the first to comment.</p>
        </div>
      <% end %>
    </div>

  </main>
</div>