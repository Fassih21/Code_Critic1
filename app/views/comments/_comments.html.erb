<%# app/views/comments/_comment.html.erb %>

<div id="<%= dom_id(comment) %>" class="flex gap-3 px-6 py-4 hover:bg-white/[0.01] transition-colors group">
  <div class="w-8 h-8 rounded-full bg-gradient-to-br from-violet-500/80 to-indigo-600/80 flex items-center justify-center text-white text-xs font-semibold shrink-0 mt-0.5">
    <%= comment.user.name.first.upcase rescue "?" %>
  </div>
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2 mb-1">
      <span class="text-white text-sm font-medium"><%= comment.user.name %></span>
      <span class="text-zinc-700 text-xs">·</span>
      <time class="text-zinc-600 text-xs" datetime="<%= comment.created_at.iso8601 %>">
        <%= comment.created_at.strftime("%b %d, %Y at %H:%M") %>
      </time>
      <% if current_user == comment.user %>
        <div class="ml-auto opacity-0 group-hover:opacity-100 transition-opacity">
          <%= button_to [comment.code_file.project, comment.code_file, comment],
                method: :delete,
                data: { turbo_stream: true, confirm: "Delete this comment?" },
                class: "text-zinc-600 hover:text-red-400 transition-colors p-1 rounded-lg hover:bg-red-500/10 cursor-pointer border-0 bg-transparent" do %>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
          <% end %>
        </div>
      <% end %>
    </div>
    <p class="text-zinc-300 text-sm leading-relaxed"><%= comment.body %></p>
  </div>
</div>