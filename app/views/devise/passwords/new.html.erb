<%# app/views/devise/passwords/new.html.erb %>
<div class="min-h-screen bg-[#0a0a0f] flex items-center justify-center px-4 py-12 font-['DM_Sans',sans-serif]">
  <div class="pointer-events-none fixed inset-0 overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] rounded-full bg-violet-600/8 blur-[120px]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] rounded-full bg-indigo-500/8 blur-[100px]"></div>
  </div>

  <div class="relative w-full max-w-md">
    <div class="text-center mb-10">
      <a href="/" class="inline-flex items-center gap-2">
        <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center shadow-lg shadow-violet-500/30">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
        </div>
        <span class="text-white text-xl font-semibold tracking-tight">Code<span class="text-violet-400">Critic</span></span>
      </a>
    </div>

    <% if notice.present? %>
      <div class="mb-6 flex items-start gap-3 rounded-xl border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-emerald-300 text-sm">
        <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span><%= notice %></span>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="mb-6 flex items-start gap-3 rounded-xl border border-red-500/30 bg-red-500/10 px-4 py-3 text-red-300 text-sm">
        <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
        </svg>
        <span><%= alert %></span>
      </div>
    <% end %>

    <div class="rounded-2xl border border-white/[0.07] bg-white/[0.03] backdrop-blur-sm p-8 shadow-2xl">
      <div class="flex flex-col items-start mb-8">
        <div class="w-12 h-12 rounded-xl bg-violet-500/15 border border-violet-500/25 flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
          </svg>
        </div>
        <h1 class="text-white text-2xl font-semibold mb-1">Reset password</h1>
        <p class="text-zinc-500 text-sm leading-relaxed">Enter your email and we'll send you a reset link.</p>
      </div>

      <% if resource.errors.any? %>
        <div class="mb-6 rounded-xl border border-red-500/25 bg-red-500/10 p-4">
          <ul class="space-y-1">
            <% resource.errors.full_messages.each do |msg| %>
              <li class="text-red-300 text-sm flex items-center gap-1.5">
                <svg class="w-3 h-3 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                <%= msg %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name),
            html: { method: :post, class: "space-y-5" }, data: { turbo: true }) do |f| %>

        <div class="space-y-1.5">
          <%= f.label :email, class: "block text-xs font-medium text-zinc-400 uppercase tracking-wider" %>
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
              <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com",
                  class: "w-full rounded-xl border #{resource.errors[:email].any? ? 'border-red-500/50 bg-red-500/5' : 'border-white/10 bg-white/5'} text-white placeholder-zinc-600 py-3 pl-10 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all duration-200 hover:border-white/20" %>
          </div>
          <% if resource.errors[:email].any? %>
            <p class="text-red-400 text-xs flex items-center gap-1"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg><%= resource.errors[:email].first %></p>
          <% end %>
        </div>

        <%= f.submit "Send reset instructions", class: "w-full py-3 px-6 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-violet-500/50 shadow-lg shadow-violet-500/20 transition-all duration-200 cursor-pointer" %>
      <% end %>

      <div class="mt-6 pt-6 border-t border-white/[0.06] flex items-center justify-center gap-4 text-sm">
        <%= link_to "← Back to sign in", new_user_session_path, class: "text-zinc-500 hover:text-zinc-300 transition-colors" %>
        <span class="text-zinc-700">·</span>
        <%= link_to "Create account", new_user_registration_path, class: "text-violet-400 hover:text-violet-300 transition-colors" %>
      </div>
    </div>
  </div>
</div>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">