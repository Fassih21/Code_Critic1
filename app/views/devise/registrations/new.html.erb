<%# app/views/devise/registrations/new.html.erb %>
<div class="min-h-screen bg-[#0a0a0f] flex items-center justify-center px-4 py-12 font-['DM_Sans',sans-serif]">
  <div class="pointer-events-none fixed inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-20 w-[500px] h-[500px] rounded-full bg-indigo-600/10 blur-[120px]"></div>
    <div class="absolute -bottom-20 -left-40 w-[500px] h-[500px] rounded-full bg-violet-500/8 blur-[100px]"></div>
  </div>

  <div class="relative w-full max-w-md">
    <div class="text-center mb-10">
      <a href="/" class="inline-flex items-center gap-2">
        <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center shadow-lg shadow-violet-500/30">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
        </div>
        <span class="text-white text-xl font-semibold tracking-tight">Code<span class="text-violet-400">Critic</span></span>
      </a>
      <p class="mt-4 text-zinc-400 text-sm">Create your account and start shipping better code.</p>
    </div>

    <% if notice.present? %>
      <div class="mb-6 flex items-start gap-3 rounded-xl border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-emerald-300 text-sm">
        <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span><%= notice %></span>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="mb-6 flex items-start gap-3 rounded-xl border border-red-500/30 bg-red-500/10 px-4 py-3 text-red-300 text-sm">
        <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
        </svg>
        <span><%= alert %></span>
      </div>
    <% end %>

    <div class="rounded-2xl border border-white/[0.07] bg-white/[0.03] backdrop-blur-sm p-8 shadow-2xl">
      <h1 class="text-white text-2xl font-semibold mb-1">Create account</h1>
      <p class="text-zinc-500 text-sm mb-8">Free forever. No credit card required.</p>

      <% if resource.errors.any? %>
        <div class="mb-6 rounded-xl border border-red-500/25 bg-red-500/10 p-4">
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-4 h-4 text-red-400 shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
            <p class="text-red-400 text-sm font-medium">Please fix the following errors:</p>
          </div>
          <ul class="space-y-1 pl-6 list-disc">
            <% resource.errors.full_messages.each do |msg| %>
              <li class="text-red-300 text-sm"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
            html: { class: "space-y-5" }, data: { turbo: true }) do |f| %>

        <div class="space-y-1.5">
          <%= f.label :name, class: "block text-xs font-medium text-zinc-400 uppercase tracking-wider" %>
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
              <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <%= f.text_field :name, autofocus: true, autocomplete: "name", placeholder: "John Doe",
                  class: "w-full rounded-xl border #{resource.errors[:name].any? ? 'border-red-500/50 bg-red-500/5' : 'border-white/10 bg-white/5'} text-white placeholder-zinc-600 py-3 pl-10 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all duration-200 hover:border-white/20" %>
          </div>
          <% if resource.errors[:name].any? %>
            <p class="text-red-400 text-xs flex items-center gap-1"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg><%= resource.errors[:name].first %></p>
          <% end %>
        </div>

        <div class="space-y-1.5">
          <%= f.label :email, class: "block text-xs font-medium text-zinc-400 uppercase tracking-wider" %>
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
              <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <%= f.email_field :email, autocomplete: "email", placeholder: "you@example.com",
                  class: "w-full rounded-xl border #{resource.errors[:email].any? ? 'border-red-500/50 bg-red-500/5' : 'border-white/10 bg-white/5'} text-white placeholder-zinc-600 py-3 pl-10 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all duration-200 hover:border-white/20" %>
          </div>
          <% if resource.errors[:email].any? %>
            <p class="text-red-400 text-xs flex items-center gap-1"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg><%= resource.errors[:email].first %></p>
          <% end %>
        </div>

        <div class="space-y-1.5">
          <%= f.label :password, class: "block text-xs font-medium text-zinc-400 uppercase tracking-wider" %>
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
              <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
            </div>
            <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••",
                  class: "w-full rounded-xl border #{resource.errors[:password].any? ? 'border-red-500/50 bg-red-500/5' : 'border-white/10 bg-white/5'} text-white placeholder-zinc-600 py-3 pl-10 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all duration-200 hover:border-white/20" %>
          </div>
          <% if resource.errors[:password].any? %>
            <p class="text-red-400 text-xs flex items-center gap-1"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg><%= resource.errors[:password].first %></p>
          <% end %>
        </div>

        <div class="space-y-1.5">
          <%= f.label :password_confirmation, "Confirm Password", class: "block text-xs font-medium text-zinc-400 uppercase tracking-wider" %>
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
              <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••",
                  class: "w-full rounded-xl border #{resource.errors[:password_confirmation].any? ? 'border-red-500/50 bg-red-500/5' : 'border-white/10 bg-white/5'} text-white placeholder-zinc-600 py-3 pl-10 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all duration-200 hover:border-white/20" %>
          </div>
        </div>

        <%= f.submit "Create account", class: "w-full py-3 px-6 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-violet-500/50 shadow-lg shadow-violet-500/20 transition-all duration-200 cursor-pointer" %>
      <% end %>
    </div>

    <p class="text-center text-sm text-zinc-600 mt-6">
      Already have an account?
      <%= link_to "Sign in →", new_user_session_path, class: "text-violet-400 hover:text-violet-300 font-medium transition-colors" %>
    </p>
  </div>
</div>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">