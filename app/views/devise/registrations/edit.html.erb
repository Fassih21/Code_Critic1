<%# app/views/devise/registrations/edit.html.erb %>
<div class="min-h-screen bg-[#0a0a0f] px-4 py-12 font-['DM_Sans',sans-serif]">
  <div class="pointer-events-none fixed inset-0 overflow-hidden">
    <div class="absolute -top-20 -right-20 w-[400px] h-[400px] rounded-full bg-violet-600/8 blur-[100px]"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full bg-indigo-500/6 blur-[100px]"></div>
  </div>

  <div class="relative max-w-2xl mx-auto">
    <div class="flex items-center justify-between mb-10">
      <a href="/" class="inline-flex items-center gap-2">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center shadow-lg shadow-violet-500/30">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
        </div>
        <span class="text-white text-lg font-semibold tracking-tight">Code<span class="text-violet-400">Critic</span></span>
      </a>
      <%= link_to "← Dashboard", root_path, class: "text-sm text-zinc-500 hover:text-zinc-300 transition-colors" %>
    </div>

    <% if notice.present? %>
      <div class="mb-6 flex items-start gap-3 rounded-xl border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-emerald-300 text-sm">
        <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span><%= notice %></span>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="mb-6 flex items-start gap-3 rounded-xl border border-red-500/30 bg-red-500/10 px-4 py-3 text-red-300 text-sm">
        <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
        </svg>
        <span><%= alert %></span>
      </div>
    <% end %>

    <div class="mb-8">
      <h1 class="text-white text-3xl font-semibold mb-1">Account Settings</h1>
      <p class="text-zinc-500 text-sm">Manage your profile and security preferences.</p>
    </div>

    <% if resource.errors.any? %>
      <div class="mb-6 rounded-xl border border-red-500/25 bg-red-500/10 p-4">
        <div class="flex items-center gap-2 mb-2">
          <svg class="w-4 h-4 text-red-400 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
          </svg>
          <p class="text-red-400 text-sm font-medium"><%= pluralize(resource.errors.count, "error") %> prevented this form from saving:</p>
        </div>
        <ul class="space-y-1 pl-6 list-disc">
          <% resource.errors.full_messages.each do |msg| %>
            <li class="text-red-300 text-sm"><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
          html: { method: :put, class: "space-y-6" }, data: { turbo: true }) do |f| %>

      <%# Profile Info %>
      <div class="rounded-2xl border border-white/[0.07] bg-white/[0.03] backdrop-blur-sm p-6 shadow-xl">
        <div class="flex items-center gap-2 mb-6">
          <div class="w-1 h-5 rounded-full bg-gradient-to-b from-violet-500 to-indigo-500"></div>
          <h2 class="text-white font-semibold">Profile Information</h2>
        </div>
        <div class="space-y-5">
          <div class="flex items-center gap-4 pb-5 border-b border-white/[0.06]">
            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center text-white text-xl font-semibold shadow-lg shadow-violet-500/20">
              <%= current_user.name.present? ? current_user.name.first.upcase : "?" %>
            </div>
            <div>
              <p class="text-white text-sm font-medium"><%= current_user.name %></p>
              <p class="text-zinc-500 text-xs mt-0.5"><%= current_user.email %></p>
            </div>
          </div>

          <div class="space-y-1.5">
            <%= f.label :name, class: "block text-xs font-medium text-zinc-400 uppercase tracking-wider" %>
            <div class="relative">
              <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
                <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
              <%= f.text_field :name, autocomplete: "name",
                    class: "w-full rounded-xl border #{resource.errors[:name].any? ? 'border-red-500/50 bg-red-500/5' : 'border-white/10 bg-white/5'} text-white placeholder-zinc-600 py-3 pl-10 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all duration-200 hover:border-white/20" %>
            </div>
          </div>

          <div class="space-y-1.5">
            <%= f.label :email, class: "block text-xs font-medium text-zinc-400 uppercase tracking-wider" %>
            <div class="relative">
              <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
                <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <%= f.email_field :email, autocomplete: "email",
                    class: "w-full rounded-xl border #{resource.errors[:email].any? ? 'border-red-500/50 bg-red-500/5' : 'border-white/10 bg-white/5'} text-white placeholder-zinc-600 py-3 pl-10 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all duration-200 hover:border-white/20" %>
            </div>
          </div>
        </div>
      </div>

      <%# Change Password %>
      <div class="rounded-2xl border border-white/[0.07] bg-white/[0.03] backdrop-blur-sm p-6 shadow-xl">
        <div class="flex items-center gap-2 mb-2">
          <div class="w-1 h-5 rounded-full bg-gradient-to-b from-violet-500 to-indigo-500"></div>
          <h2 class="text-white font-semibold">Change Password</h2>
        </div>
        <p class="text-zinc-500 text-xs mb-6 ml-3">Leave blank to keep your current password.</p>
        <div class="space-y-5">
          <div class="space-y-1.5">
            <%= f.label :password, "New Password", class: "block text-xs font-medium text-zinc-400 uppercase tracking-wider" %>
            <div class="relative">
              <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
                <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
              </div>
              <%= f.password_field :password, autocomplete: "new-password", placeholder: "Leave blank to keep current",
                    class: "w-full rounded-xl border border-white/10 bg-white/5 text-white placeholder-zinc-600 py-3 pl-10 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all duration-200 hover:border-white/20" %>
            </div>
          </div>
          <div class="space-y-1.5">
            <%= f.label :password_confirmation, "Confirm New Password", class: "block text-xs font-medium text-zinc-400 uppercase tracking-wider" %>
            <div class="relative">
              <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
                <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </div>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirm new password",
                    class: "w-full rounded-xl border border-white/10 bg-white/5 text-white placeholder-zinc-600 py-3 pl-10 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all duration-200 hover:border-white/20" %>
            </div>
          </div>
        </div>
      </div>

      <%# Current Password confirmation %>
      <div class="rounded-2xl border border-amber-500/15 bg-amber-500/5 p-6 shadow-xl">
        <div class="flex items-start gap-3 mb-5">
          <svg class="w-5 h-5 text-amber-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
          <div>
            <p class="text-amber-300 text-sm font-medium">Security confirmation required</p>
            <p class="text-amber-300/60 text-xs mt-0.5">Enter your current password to save any changes.</p>
          </div>
        </div>
        <div class="space-y-1.5">
          <%= f.label :current_password, "Current Password", class: "block text-xs font-medium text-zinc-400 uppercase tracking-wider" %>
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
              <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
              </svg>
            </div>
            <%= f.password_field :current_password, autocomplete: "current-password", placeholder: "Your current password",
                  class: "w-full rounded-xl border #{resource.errors[:current_password].any? ? 'border-red-500/50 bg-red-500/5' : 'border-white/10 bg-white/5'} text-white placeholder-zinc-600 py-3 pl-10 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all duration-200 hover:border-white/20" %>
          </div>
          <% if resource.errors[:current_password].any? %>
            <p class="text-red-400 text-xs flex items-center gap-1"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg><%= resource.errors[:current_password].first %></p>
          <% end %>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-2">
        <%= f.submit "Save changes", class: "w-full sm:w-auto px-8 py-3 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-violet-500/50 shadow-lg shadow-violet-500/20 transition-all duration-200 cursor-pointer" %>
        <%= link_to "Cancel", :back, class: "w-full sm:w-auto text-center px-8 py-3 rounded-xl text-sm font-medium text-zinc-400 border border-white/10 hover:border-white/20 hover:text-white transition-all duration-200" %>
      </div>
    <% end %>

    <%# Danger Zone %>
    <div class="mt-8 rounded-2xl border border-red-500/15 bg-red-500/5 p-6">
      <h3 class="text-red-400 font-semibold mb-1 flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Danger Zone
      </h3>
      <p class="text-zinc-500 text-sm mb-4">Permanently delete your account. This cannot be undone.</p>
      <%= button_to "Delete my account", registration_path(resource_name),
            data: { method: :delete, confirm: "Are you absolutely sure? This cannot be undone." },
            class: "px-5 py-2.5 rounded-xl text-xs font-semibold text-red-400 border border-red-500/30 hover:bg-red-500/10 hover:border-red-400/50 transition-all duration-200 cursor-pointer" %>
    </div>
  </div>
</div>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">