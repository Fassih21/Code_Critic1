<%# app/views/projects/index.html.erb %>

<div class="min-h-screen bg-[#0a0a0f] font-['DM_Sans',sans-serif]">
  <%= render "shared/navbar" %>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <%= render "shared/flash" %>

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-10">
      <div>
        <h1 class="text-white text-3xl font-semibold tracking-tight">Projects</h1>
        <p class="text-zinc-500 text-sm mt-1"><%= pluralize(@projects.count, "project") %> in your workspace</p>
      </div>
      <%= link_to new_project_path, class: "inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 shadow-lg shadow-violet-500/20 active:scale-[0.98] transition-all duration-200" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        New Project
      <% end %>
    </div>

    <% if @projects.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <% @projects.each do |project| %>
          <div class="group relative flex flex-col rounded-2xl border border-white/[0.07] bg-white/[0.03] hover:border-violet-500/30 hover:bg-white/[0.05] transition-all duration-300 overflow-hidden">
            <div class="h-[2px] w-full bg-gradient-to-r from-violet-600/60 via-indigo-500/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="flex flex-col flex-1 p-6">
              <div class="flex items-start justify-between mb-4">
                <div class="w-10 h-10 rounded-xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
                  </svg>
                </div>
                <span class="text-xs text-zinc-600 mt-1"><%= project.created_at.strftime("%b %d, %Y") %></span>
              </div>

              <h2 class="text-white font-semibold text-lg mb-2 leading-snug group-hover:text-violet-200 transition-colors">
                <%= project.name %>
              </h2>
              <p class="text-zinc-500 text-sm leading-relaxed flex-1 line-clamp-3">
                <%= project.description.presence || "No description provided." %>
              </p>

              <div class="flex items-center justify-between mt-6 pt-4 border-t border-white/[0.06]">
                <div class="flex items-center gap-1.5 text-xs text-zinc-600">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                  <%= pluralize(project.code_files.count, "file") %>
                </div>
                <%= link_to project_path(project), class: "inline-flex items-center gap-1.5 text-sm font-medium text-violet-400 hover:text-violet-300 transition-colors group/btn" do %>
                  View Project
                  <svg class="w-3.5 h-3.5 group-hover/btn:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

    <% else %>
      <div class="flex flex-col items-center justify-center py-28 text-center">
        <div class="w-20 h-20 rounded-2xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center mb-6">
          <svg class="w-9 h-9 text-violet-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
          </svg>
        </div>
        <h2 class="text-white text-xl font-semibold mb-2">No projects yet</h2>
        <p class="text-zinc-500 text-sm mb-8 max-w-xs leading-relaxed">Create your first project and start getting AI-powered code reviews.</p>
        <%= link_to new_project_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 shadow-lg shadow-violet-500/20 active:scale-[0.98] transition-all duration-200" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Create your first project
        <% end %>
      </div>
    <% end %>
  </main>
</div>