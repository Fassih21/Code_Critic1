<%# app/views/projects/new.html.erb %>

<div class="min-h-screen bg-[#0a0a0f] font-['DM_Sans',sans-serif]">
  <%= render "shared/navbar" %>

  <main class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <%= render "shared/flash" %>

    <%# Breadcrumb %>
    <nav class="flex items-center gap-2 text-sm text-zinc-600 mb-8">
      <%= link_to "Projects", projects_path, class: "hover:text-zinc-400 transition-colors" %>
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="text-zinc-400">New Project</span>
    </nav>

    <div class="rounded-2xl border border-white/[0.07] bg-white/[0.03] p-8 shadow-2xl">
      <h1 class="text-white text-2xl font-semibold mb-1">New Project</h1>
      <p class="text-zinc-500 text-sm mb-8">Create a project to start uploading code for AI review.</p>

      <%# Validation errors %>
      <% if @project.errors.any? %>
        <div class="mb-6 rounded-xl border border-red-500/25 bg-red-500/10 p-4">
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-4 h-4 text-red-400 shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
            <p class="text-red-400 text-sm font-medium">Please fix the following errors:</p>
          </div>
          <ul class="space-y-1 pl-6 list-disc">
            <% @project.errors.full_messages.each do |msg| %>
              <li class="text-red-300 text-sm"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @project, url: projects_path, data: { turbo: true }, class: "space-y-5" do |f| %>

        <%# Name %>
        <div class="space-y-1.5">
          <%= f.label :name, class: "block text-xs font-medium text-zinc-400 uppercase tracking-wider" %>
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
              <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
              </svg>
            </div>
            <%= f.text_field :name,
                  placeholder: "My Awesome Project",
                  autofocus: true,
                  class: "w-full rounded-xl border #{@project.errors[:name].any? ? 'border-red-500/50 bg-red-500/5' : 'border-white/10 bg-white/5'}
                          text-white placeholder-zinc-600
                          py-3 pl-10 pr-4 text-sm
                          focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50
                          transition-all duration-200 hover:border-white/20" %>
          </div>
          <% if @project.errors[:name].any? %>
            <p class="text-red-400 text-xs flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
              <%= @project.errors[:name].first %>
            </p>
          <% end %>
        </div>

        <%# Description %>
        <div class="space-y-1.5">
          <%= f.label :description, class: "block text-xs font-medium text-zinc-400 uppercase tracking-wider" %>
          <%= f.text_area :description,
                placeholder: "What is this project about?",
                rows: 4,
                class: "w-full rounded-xl border #{@project.errors[:description].any? ? 'border-red-500/50 bg-red-500/5' : 'border-white/10 bg-white/5'}
                        text-white placeholder-zinc-600
                        py-3 px-4 text-sm
                        focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50
                        transition-all duration-200 hover:border-white/20 resize-none" %>
          <% if @project.errors[:description].any? %>
            <p class="text-red-400 text-xs flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
              <%= @project.errors[:description].first %>
            </p>
          <% end %>
        </div>

        <%# Buttons %>
        <div class="flex items-center gap-3 pt-2">
          <%= f.submit "Create Project",
                class: "px-6 py-2.5 rounded-xl text-sm font-semibold text-white
                        bg-gradient-to-r from-violet-600 to-indigo-600
                        hover:from-violet-500 hover:to-indigo-500
                        active:scale-[0.98] transition-all duration-200
                        shadow-lg shadow-violet-500/20 cursor-pointer" %>
          <%= link_to "Cancel", projects_path,
                class: "px-6 py-2.5 rounded-xl text-sm font-medium text-zinc-400
                        border border-white/10 hover:border-white/20 hover:text-white
                        transition-all duration-200" %>
        </div>

      <% end %>
    </div>
  </main>
</div>